# Copy this file to `.env.local` and fill in the values for local development.
#
# Values prefixed with `VITE_` are exposed to the client bundle. Never put
# secrets (server API keys, signing keys, etc.) in VITE_ variables — they
# will be readable by anyone who loads the app.

# Base44 app identifier. Required for the SDK to know which app to talk to.
VITE_BASE44_APP_ID=your-base44-app-id

# Base URL for the Base44 backend the app should hit. Point at the staging
# deployment for local dev, and production for production builds.
VITE_BASE44_APP_BASE_URL=https://app.base44.com

# Optional: pins the backend functions version. Leave unset to use the
# deployment default.
# VITE_BASE44_FUNCTIONS_VERSION=

# Optional: enable legacy SDK import aliases (@/integrations, @/entities, etc.)
# during the Vite build. Only needed if you haven't migrated to the new
# @base44/sdk imports yet.
# BASE44_LEGACY_SDK_IMPORTS=true
