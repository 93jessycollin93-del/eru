{
  "name": "BotFarmOutputLog",
  "type": "object",
  "properties": {
    "bot_id": { "type": "string" },
    "task_id": { "type": "string" },
    "mission_id": { "type": "string" },
    "output_type": {
      "type": "string",
      "enum": ["collected_data", "processed_intelligence", "summary", "alert", "report", "verified_finding", "mission_progress", "system_efficiency", "resource_gain"]
    },
    "quality_score": { "type": "number", "default": 75 },
    "value_score": { "type": "number", "default": 50 },
    "specialization_fit_score": { "type": "number", "default": 0 },
    "coordination_penalty": { "type": "number", "default": 0 },
    "management_boost": { "type": "number", "default": 0 },
    "contradiction_risk": { "type": "number", "default": 0 },
    "summary": { "type": "string" }
  },
  "required": ["output_type", "summary"],
  "rls": {
    "create": { "created_by": "{{user.email}}" },
    "read": { "created_by": "{{user.email}}" },
    "update": { "created_by": "{{user.email}}" },
    "delete": { "created_by": "{{user.email}}" }
  }
}