{
  "name": "Card",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "cost": {
      "type": "number",
      "description": "Energy cost 1-7"
    },
    "power": {
      "type": "number",
      "description": "Board power contribution"
    },
    "guard": {
      "type": "number",
      "description": "Damage absorption"
    },
    "element": {
      "type": "string",
      "enum": [
        "fire",
        "water",
        "earth",
        "wind",
        "shadow",
        "light"
      ]
    },
    "faction": {
      "type": "string"
    },
    "card_type": {
      "type": "string",
      "enum": [
        "unit",
        "spell",
        "relic"
      ]
    },
    "rarity": {
      "type": "string",
      "enum": [
        "common",
        "rare",
        "epic",
        "legendary",
        "mythic"
      ]
    },
    "ability": {
      "type": "string",
      "description": "Ability keyword: burn, frost, poison, shield, combo, clash, summon, draw, heal"
    },
    "ability_value": {
      "type": "number",
      "description": "Ability effect magnitude"
    },
    "flavor_text": {
      "type": "string"
    },
    "creature_id": {
      "type": "string",
      "description": "Set if bred from Creature Lab"
    },
    "source_creature_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "transmuted_from_card_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "is_transmuted": {
      "type": "boolean",
      "default": false
    },
    "is_animated": {
      "type": "boolean",
      "default": false
    },
    "quantity": {
      "type": "number",
      "default": 1,
      "description": "Copies owned"
    },
    "ownership_timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string"
          },
          "acquired_at": {
            "type": "string"
          },
          "transferred_at": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "lore_origin": {
      "type": "string",
      "description": "Signal source / where this card was first detected (e.g. 'Echo Drift 7-\u03a3', 'Monolith Sector 12')"
    },
    "lore_tag": {
      "type": "string",
      "description": "Narrative tag from the excavation event that surfaced it"
    },
    "stability_visible": {
      "type": "number",
      "description": "Public stability rating 0-100, shown to the player"
    },
    "stability_hidden": {
      "type": "number",
      "description": "True stability rating 0-100, used for narrative drift only \u2014 never affects battle math"
    },
    "historical_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event_type": {
            "type": "string",
            "enum": [
              "origin",
              "battle",
              "ownership",
              "pack",
              "drift"
            ]
          },
          "summary": {
            "type": "string"
          },
          "actor": {
            "type": "string"
          },
          "result": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "default": [],
      "description": "Immutable lore log of battles, ownership transfers, and excavation events"
    }
  },
  "required": [
    "name",
    "cost",
    "power",
    "element",
    "card_type",
    "rarity"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}