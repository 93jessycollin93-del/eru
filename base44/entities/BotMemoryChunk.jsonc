{
  "name": "BotMemoryChunk",
  "type": "object",
  "properties": {
    "bot_id": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "chunk_key": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "message_count": {
      "type": "number",
      "default": 0
    },
    "archive_file_uri": {
      "type": "string"
    },
    "archive_signed_url": {
      "type": "string"
    },
    "storage_tier": {
      "type": "string",
      "enum": [
        "hot",
        "warm",
        "cold"
      ],
      "default": "warm"
    },
    "last_message_at": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "retrieval_score": {
      "type": "number",
      "default": 50
    },
    "memory_category": {
      "type": "string",
      "enum": [
        "conversation",
        "preference",
        "fact",
        "task",
        "strategy",
        "system"
      ],
      "default": "conversation"
    },
    "source_memory_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "compression_ratio": {
      "type": "number",
      "default": 1
    },
    "last_accessed_at": {
      "type": "string"
    },
    "access_count": {
      "type": "number",
      "default": 0
    },
    "quality_score": {
      "type": "number",
      "default": 70
    }
  },
  "required": [
    "bot_id",
    "user_email",
    "chunk_key",
    "summary"
  ]
}