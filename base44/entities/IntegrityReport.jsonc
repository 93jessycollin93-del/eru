{
  "name": "IntegrityReport",
  "type": "object",
  "properties": {
    "mission_id": {
      "type": "string"
    },
    "bot_code": {
      "type": "string"
    },
    "squad_name": {
      "type": "string"
    },
    "anomaly_type": {
      "type": "string"
    },
    "integrity_score": {
      "type": "number",
      "default": 90
    },
    "stability_score": {
      "type": "number",
      "default": 88
    },
    "details": {
      "type": "string"
    }
  },
  "required": [
    "details"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}