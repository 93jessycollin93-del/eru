{
  "name": "BotFarmActivityHistory",
  "type": "object",
  "properties": {
    "actor_type": {
      "type": "string",
      "enum": [
        "bot",
        "squad",
        "farm",
        "system"
      ]
    },
    "actor_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "impact_score": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "actor_type",
    "event_type",
    "summary"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}