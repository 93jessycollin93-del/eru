{
  "name": "BotFarmMetric",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional free-form description (max 1000 chars)"
    },
    "total_bots": {
      "type": "number",
      "default": 0
    },
    "active_bots": {
      "type": "number",
      "default": 0
    },
    "idle_bots": {
      "type": "number",
      "default": 0
    },
    "overloaded_bots": {
      "type": "number",
      "default": 0
    },
    "maintenance_bots": {
      "type": "number",
      "default": 0
    },
    "output_rate": {
      "type": "number",
      "default": 0
    },
    "mission_progress": {
      "type": "number",
      "default": 0
    },
    "system_efficiency": {
      "type": "number",
      "default": 75
    },
    "integrity_warning_count": {
      "type": "number",
      "default": 0
    },
    "security_alert_count": {
      "type": "number",
      "default": 0
    },
    "task_queue_depth": {
      "type": "number",
      "default": 0
    }
  },
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  },
  "required": []
}