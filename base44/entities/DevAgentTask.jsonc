{
  "name": "DevAgentTask",
  "type": "object",
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "task_type": {
      "type": "string",
      "enum": [
        "scaffold",
        "refactor",
        "ui",
        "backend",
        "data_model",
        "test",
        "doc",
        "manual"
      ],
      "default": "manual"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "planning",
        "ready",
        "blocked",
        "needs_setup",
        "running",
        "completed",
        "failed",
        "manually_exported"
      ],
      "default": "queued"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "queue_index": {
      "type": "number",
      "default": 0
    },
    "input_context": {
      "type": "string"
    },
    "output_summary": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "owner_email": {
      "type": "string"
    }
  },
  "required": [
    "plan_id",
    "title"
  ],
  "rls": {
    "create": {
      "owner_email": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}