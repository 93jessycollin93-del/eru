{
  "name": "CardMatchmakingRoom",
  "type": "object",
  "properties": {
    "room_key": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "pvp_ladder",
        "ai_campaign",
        "training",
        "tutorial",
        "jackie_ai"
      ],
      "default": "pvp_ladder"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "ready",
        "completed"
      ],
      "default": "pending"
    },
    "player_one_email": {
      "type": "string"
    },
    "player_two_email": {
      "type": "string"
    },
    "player_one_name": {
      "type": "string"
    },
    "player_two_name": {
      "type": "string"
    },
    "player_one_elo": {
      "type": "number"
    },
    "player_two_elo": {
      "type": "number"
    },
    "player_one_deck_strength": {
      "type": "number"
    },
    "player_two_deck_strength": {
      "type": "number"
    },
    "player_one_deck_snapshot": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "element": {
            "type": "string"
          },
          "rarity": {
            "type": "string"
          },
          "cost": {
            "type": "number"
          },
          "power": {
            "type": "number"
          },
          "guard": {
            "type": "number"
          },
          "ability": {
            "type": "string"
          },
          "ability_value": {
            "type": "number"
          }
        }
      },
      "default": []
    },
    "player_two_deck_snapshot": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "element": {
            "type": "string"
          },
          "rarity": {
            "type": "string"
          },
          "cost": {
            "type": "number"
          },
          "power": {
            "type": "number"
          },
          "guard": {
            "type": "number"
          },
          "ability": {
            "type": "string"
          },
          "ability_value": {
            "type": "number"
          }
        }
      },
      "default": []
    },
    "winner_email": {
      "type": "string"
    },
    "campaign_level": {
      "type": "number"
    }
  },
  "required": [
    "room_key",
    "mode",
    "status"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}