{
  "name": "BotCollaborationSession",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional free-form description (max 1000 chars)"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "running",
        "completed",
        "failed"
      ],
      "default": "draft"
    },
    "selected_bot_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "delegation_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "bot_id": {
            "type": "string"
          },
          "bot_name": {
            "type": "string"
          },
          "task": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "bot_id": {
            "type": "string"
          },
          "bot_name": {
            "type": "string"
          },
          "task": {
            "type": "string"
          },
          "finding": {
            "type": "string"
          },
          "assignment": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "feedback": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "reviewer_bot_id": {
            "type": "string"
          },
          "reviewer_bot_name": {
            "type": "string"
          },
          "from_bot_id": {
            "type": "string"
          },
          "to_bot_id": {
            "type": "string"
          },
          "feedback": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "final_output": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "goal"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}