{
  "name": "BotFarmRiskFlag",
  "type": "object",
  "properties": {
    "bot_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "mission_id": {
      "type": "string"
    },
    "squad_id": {
      "type": "string"
    },
    "flag_type": {
      "type": "string",
      "enum": [
        "anomaly",
        "low_confidence",
        "contradiction",
        "integrity_drop",
        "unstable",
        "security_issue",
        "overload",
        "poor_assignment"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "critical"
      ],
      "default": "warning"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "reviewing",
        "resolved"
      ],
      "default": "open"
    },
    "details": {
      "type": "string"
    }
  },
  "required": [
    "flag_type",
    "details"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}